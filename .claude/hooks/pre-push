#!/usr/bin/env bash
# pre-push hook — Valida nomenclatura de branch e existência de task
# Referência: .claude/rules/05-convencoes.md (Seção 5.3), .claude/rules/09-enforcement.md
# Instalado pela TASK-000. Bypass: git push --no-verify

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

# Permite push em branches protegidas sem validação
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ] || [ "$BRANCH" = "dev" ] || [ "$BRANCH" = "develop" ]; then
  exit 0
fi

# Valida formato: type/TASK-NNN-descricao-curta
VALID_TYPES="feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert"
if ! echo "$BRANCH" | grep -qE "^($VALID_TYPES)/TASK-[A-Z0-9]+-[a-z0-9-]+$"; then
  echo ""
  echo "AVISO: Branch '$BRANCH' não segue o padrão esperado."
  echo ""
  echo "  Formato: type/TASK-NNN-descricao-curta"
  echo "  Exemplo: feat/TASK-001-login-google"
  echo ""
  echo "  Este é um aviso — o push não será bloqueado."
  echo "  Considere renomear a branch para manter rastreabilidade."
  echo ""
  # Aviso, não bloqueio (princípio de não-bloqueante em caso de dúvida)
fi

# Extrai TASK-NNN da branch
TASK_ID=$(echo "$BRANCH" | grep -oE "TASK-[A-Z0-9]+" || true)

if [ -n "$TASK_ID" ]; then
  TASKS_FILE="$(git rev-parse --show-toplevel)/.claude/tasks.md"

  if [ -f "$TASKS_FILE" ]; then
    # Verifica se a task existe no arquivo
    if ! grep -q "$TASK_ID" "$TASKS_FILE"; then
      echo ""
      echo "AVISO: $TASK_ID não encontrada em .claude/tasks.md"
      echo "  Registre a task antes de prosseguir."
      echo ""
    fi
  else
    echo ""
    echo "AVISO: .claude/tasks.md não encontrado."
    echo "  O arquivo de tasks é obrigatório para rastreabilidade."
    echo ""
  fi
fi

# Verifica se registry.md foi atualizado para tasks concluídas
REGISTRY_FILE="$(git rev-parse --show-toplevel)/.claude/registry.md"
if [ -f "$REGISTRY_FILE" ] && [ -n "$TASK_ID" ]; then
  # Busca commits sendo enviados
  REMOTE="$1"
  REMOTE_REF=$(git rev-parse "$REMOTE/$BRANCH" 2>/dev/null || echo "")

  if [ -n "$REMOTE_REF" ]; then
    COMMITS=$(git log "$REMOTE_REF..HEAD" --oneline 2>/dev/null || true)
  else
    COMMITS=$(git log --oneline -10 2>/dev/null || true)
  fi

  if echo "$COMMITS" | grep -qi "concluída\|concluida\|completed\|done"; then
    if ! git diff --name-only "$REMOTE_REF..HEAD" 2>/dev/null | grep -q "registry.md"; then
      echo ""
      echo "AVISO: Commits indicam task concluída, mas registry.md não foi atualizado."
      echo "  Atualize o Registro de Projeto antes de finalizar."
      echo ""
    fi
  fi
fi

exit 0
