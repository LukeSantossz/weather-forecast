#!/usr/bin/env bash
# commit-msg hook — Valida formato Conventional Commits
# Referência: .claude/rules/05-convencoes.md (Seção 5.2)
# Instalado pela TASK-000. Bypass: git commit --no-verify

COMMIT_MSG_FILE="$1"
MSG=$(head -1 "$COMMIT_MSG_FILE")

# Tipos válidos de Conventional Commits
VALID_TYPES="feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert"

# Valida formato: type(scope): subject  OU  type: subject
if ! echo "$MSG" | grep -qE "^($VALID_TYPES)(\([a-z0-9_-]+\))?: .{10,100}$"; then
  echo ""
  echo "ERRO: Mensagem de commit fora do padrão Conventional Commits."
  echo ""
  echo "  Formato esperado: type(scope): subject"
  echo "  Tipos válidos: feat, fix, docs, style, refactor, perf, test, chore, build, ci, revert"
  echo "  Subject: 10-100 caracteres, imperativo"
  echo ""
  echo "  Recebido: $MSG"
  echo ""
  echo "  Use --no-verify para pular (documente o motivo na próxima sessão)."
  exit 1
fi

# Rejeita body (mais de uma linha)
LINE_COUNT=$(wc -l < "$COMMIT_MSG_FILE")
if [ "$LINE_COUNT" -gt 1 ]; then
  # Verifica se linhas extras não são apenas vazias
  CONTENT_LINES=$(sed '/^$/d' "$COMMIT_MSG_FILE" | wc -l)
  if [ "$CONTENT_LINES" -gt 1 ]; then
    echo ""
    echo "ERRO: Commit contém body/descrição adicional."
    echo "  Commits devem ter APENAS a linha de subject."
    echo "  Se a mudança não cabe em uma linha, quebre em commits menores."
    exit 1
  fi
fi

# Rejeita co-autoria
if grep -qiE "^(Co-authored-by|Signed-off-by):" "$COMMIT_MSG_FILE"; then
  echo ""
  echo "ERRO: Trailers de co-autoria não são permitidos."
  echo "  Remova linhas Co-authored-by ou Signed-off-by."
  exit 1
fi

exit 0
