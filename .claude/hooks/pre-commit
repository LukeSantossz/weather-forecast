#!/usr/bin/env bash
# pre-commit hook — Detecta logs de debug em arquivos staged
# Referência: .claude/rules/09-enforcement.md
# Configuração: .claude/enforcement.conf
# Instalado pela TASK-000. Bypass: git commit --no-verify

CONF_FILE="$(git rev-parse --show-toplevel)/.claude/enforcement.conf"
FOUND=0

# Se o arquivo de configuração não existir, usa padrões default
if [ ! -f "$CONF_FILE" ]; then
  echo "AVISO: .claude/enforcement.conf não encontrado. Usando padrões default."
  # Padrões default mínimos
  DEFAULT_PATTERNS="js|console\.log\(
py|print\(
ts|console\.log\(
dart|print\("
  CONF_CONTENT="$DEFAULT_PATTERNS"
else
  CONF_CONTENT=$(cat "$CONF_FILE")
fi

# Obtém arquivos staged (apenas adições e modificações)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Para cada arquivo staged, verifica padrões correspondentes à extensão
while IFS= read -r FILE; do
  [ -z "$FILE" ] && continue
  [ ! -f "$FILE" ] && continue

  # Extrai extensão
  EXT="${FILE##*.}"

  # Busca padrões para esta extensão no conf
  while IFS='|' read -r CONF_EXT PATTERN; do
    # Ignora comentários e linhas vazias
    [[ "$CONF_EXT" =~ ^#.*$ ]] && continue
    [ -z "$CONF_EXT" ] && continue
    [ -z "$PATTERN" ] && continue

    # Remove espaços
    CONF_EXT=$(echo "$CONF_EXT" | tr -d '[:space:]')
    PATTERN=$(echo "$PATTERN" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

    if [ "$EXT" = "$CONF_EXT" ]; then
      # Verifica apenas linhas adicionadas (não removidas)
      MATCHES=$(git diff --cached -U0 "$FILE" | grep "^+" | grep -v "^+++" | grep -nE "$PATTERN" || true)
      if [ -n "$MATCHES" ]; then
        if [ "$FOUND" -eq 0 ]; then
          echo ""
          echo "AVISO: Possíveis logs de debug detectados em arquivos staged:"
          echo ""
        fi
        echo "  $FILE:"
        echo "$MATCHES" | sed 's/^/    /'
        echo ""
        FOUND=1
      fi
    fi
  done <<< "$CONF_CONTENT"
done <<< "$STAGED_FILES"

if [ "$FOUND" -eq 1 ]; then
  echo "  Remova os logs de debug antes de commitar."
  echo "  Use --no-verify para pular (documente o motivo na próxima sessão)."
  echo ""
  exit 1
fi

exit 0
