# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
.venv-run/
venv/
env/
ENV/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Jupyter and IPython
.ipynb_checkpoints/
profile_default/
ipython_config.py

# IDE and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
*.tmp
*.temp
tmp/
temp/

# Data artifacts (keep structure with .gitkeep)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/*.parquet
data/*.csv
data/*.zip
data/*.json

# Reports and generated assets
reports/*
!reports/.gitkeep

# Local secrets and environment files
.env
.env.*
kaggle.json
/tutor.md
git_vendas.pdf

# Model artifacts (persisted, versioned locally; not committed)
models/

# Web app (phase-1 dashboard)
web/node_modules/
web/.next/
web/out/
web/next-env.d.ts
web/tsconfig.tsbuildinfo

# Agent worktrees / local scratch
.claude/
